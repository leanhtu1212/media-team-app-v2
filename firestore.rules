// Firestore rules cho Media Team (app v2 + app cũ dùng chung).
// Khác bản cũ (media-team-manager (3)/firestore.rules):
//   1. members create: admin được tạo member doc cho người khác — app v2 là SPA
//      thuần không có Admin SDK server-side như app cũ, nên admin phải ghi trực
//      tiếp từ client. Bản cũ bắt request.auth.uid == userId nên admin bị chặn.
//   2. Thêm role 'content': chỉ được ghi dailyContent, không ghi projects/tasks.
// Deploy: Firebase Console → Firestore → chọn database
// ai-studio-9933e878-0247-44cf-b7f0-e77cd2ac2eac → tab Rules → dán → Publish.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isTeamMember(teamId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    function getMemberRole(teamId) {
      return get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role;
    }

    function isAdmin(teamId) {
      return isAuthenticated() && (
        request.auth.token.email == "leanhtu1212@gmail.com" ||
        request.auth.token.email == "admin@production.team" ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid ||
        (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isEditor(teamId) {
      return isTeamMember(teamId) && (getMemberRole(teamId) == 'editor' || getMemberRole(teamId) == 'admin');
    }

    // Role 'content' chỉ có quyền này (+ đọc như member thường)
    function canEditDaily(teamId) {
      return isTeamMember(teamId) && (
        getMemberRole(teamId) == 'editor' ||
        getMemberRole(teamId) == 'admin' ||
        getMemberRole(teamId) == 'content'
      );
    }

    // Collection Group for Tasks — chỉ thành viên team đọc (team id cố định, hard-code
    // được vì match collection-group không có teamId trong path).
    match /{path=**}/tasks/{taskId} {
      allow read: if isAuthenticated() &&
        exists(/databases/$(database)/documents/teams/MEDIA_TEAM_01/members/$(request.auth.uid));
    }

    // Teams Collection
    match /teams/{teamId} {
      allow read: if isTeamMember(teamId);
      allow create: if isAuthenticated();
      allow update: if isAdmin(teamId);

      // Members Subcollection
      match /members/{userId} {
        allow read: if isTeamMember(teamId);
        // Admin tạo member doc cho user mới (flow "Thêm thành viên" của SPA). User chỉ
        // được tự tạo doc của chính mình với role 'viewer' (không tự cấp editor/content
        // — repo public + config lộ nên phải chặn tự nâng quyền).
        allow create: if isAdmin(teamId) || (
          isAuthenticated() && request.auth.uid == userId &&
          request.resource.data.role == 'viewer'
        );
        allow update: if isAdmin(teamId) || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email', 'joinedAt']));
        allow delete: if isAdmin(teamId) && userId != request.auth.uid;
      }

      // Projects Subcollection
      match /projects/{projectId} {
        allow read: if isTeamMember(teamId);
        allow create: if isEditor(teamId);
        allow update: if isEditor(teamId);
        allow delete: if isAdmin(teamId);

        // Tasks Subcollection
        match /tasks/{taskId} {
          allow read: if isTeamMember(teamId);
          allow create, update: if isEditor(teamId);
          allow delete: if isEditor(teamId);
        }
      }

      // Reports Subcollection — chỉ tạo/sửa báo cáo của chính mình (admin sửa được mọi báo cáo).
      match /reports/{reportId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId) && request.resource.data.createdBy == request.auth.uid;
        allow update: if isTeamMember(teamId) &&
          (resource.data.createdBy == request.auth.uid || isAdmin(teamId));
        allow delete: if isAdmin(teamId);
      }

      // ProductTypes Subcollection
      match /productTypes/{typeId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isAdmin(teamId);
      }

      // Daily Content Subcollection — role 'content' được ghi ở đây
      match /dailyContent/{contentId} {
        allow read: if isTeamMember(teamId);
        allow create, update: if canEditDaily(teamId);
        allow delete: if canEditDaily(teamId);
      }

      // Notes Subcollection — ghi chú ghim vào ngày trên lịch (editor/admin/content ghi)
      match /notes/{noteId} {
        allow read: if isTeamMember(teamId);
        allow create, update: if canEditDaily(teamId);
        allow delete: if canEditDaily(teamId);
      }

      // Tags Subcollection — nhãn màu tuỳ chỉnh cho mục lịch (editor/admin quản lý)
      match /tags/{tagId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isEditor(teamId);
      }
    }
  }
}
